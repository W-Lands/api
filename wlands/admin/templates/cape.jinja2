{% extends "layout.jinja2" %}
{% import "macros.jinja2" as macros %}
{% from "macros.jinja2" import render_pagination with context %}

{% block title %}Cape {{ cape.name }}{% endblock %}
{% block nav_capes %}active{% endblock %}

{% block content %}
    <h1>{{ cape.name }}</h1>
    <a href="{{ url_for("admin_capes_page") }}" class="">&lt;- Back</a>
    <dl class="row">
        {{ macros.details_row("Id", cape.id) }}
        {{ macros.details_row("Name", cape.name) }}
        {{ macros.details_row("Description", cape.description) }}
        {{ macros.details_row("Public", cape.public|format_bool) }}
        {{ macros.details_row("Info public", cape.info_public|format_bool) }}
        {{ macros.details_row("Created At", cape.created_at|format_datetime) }}
    </dl>
    <div>
        <button class="btn btn-primary ms-2" data-bs-toggle="modal" data-bs-target="#edit-cape-modal">Edit</button>
    </div>

    <div class="mt-3 w-100 d-flex flex-column gap-3">
        <div class="w-100 d-flex flex-row justify-content-between">
            <h3>Users with this cape</h3>
            <button class="btn btn-primary ms-2" data-bs-toggle="modal" data-bs-target="#add-user-modal">Add user</button>
        </div>
        <form method="GET" action="{{ url_for("admin_cape_info_page", cape_id=cape.id) }}" class="w-100 d-flex flex-row">
            <input type="text" class="form-control" name="search" placeholder="Search user..." value="{{ request.query_params['search'] }}">
            <button class="btn btn-primary ms-2" type="submit">Search</button>
        </form>
        <table class="table table-striped table-bordered">
            <thead>
            <tr>
                <th>Id</th>
                <th>Nickname</th>
                <th>Selected</th>
                <th>Actions</th>
            </tr>
            </thead>
            <tbody>
            {% for user_cape in users %}
                <tr class="align-middle">
                    <td><a href="{{ url_for("admin_user_info_page", user_id=user_cape.user_id) }}">{{ user_cape.user_id }}</a></td>
                    <td>{{ user_cape.user.nickname }}</td>
                    <td>{{ user_cape.selected|format_bool }}</td>
                    <td>
                        <form method="POST" action="{{ url_for("admin_cape_remove_user", cape_id=cape.id, user_id=user_cape.user_id) }}" class="w-100 d-inline flex-row">
                            <button class="btn btn-danger btn-sm ms-2" type="submit">Remove</button>
                        </form>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

        {{ render_pagination(pagination, append_query_to_url(url_for("admin_cape_info_page", cape_id=cape.id), request, "search")) }}
    </div>

    <div class="modal fade" id="edit-cape-modal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h1 class="modal-title fs-5">Edit cape</h1>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form action="{{ url_for("admin_cape_edit", cape_id=cape.id) }}" method="POST" id="edit-cape-form">
                        <div class="mb-3">
                            <label for="name-input" class="form-label fw-bold">Name</label>
                            <input type="text" class="form-control" id="name-input" name="name" required value="{{ cape.name }}">
                        </div>
                        <div class="mb-3">
                            <label for="description-input" class="form-label fw-bold">Description</label>
                            <textarea class="form-control" id="description-input" name="description" required>{{ cape.description }}</textarea>
                        </div>
                        <div class="mb-3 form-check">
                            <label for="cape-public-checkbox" class="form-label form-check-label">Public</label>
                            <input type="checkbox" class="form-check-input" id="cape-public-checkbox" name="public" {% if cape.public %}checked{% endif %}>
                        </div>
                        <div class="mb-3 form-check">
                            <label for="info-public-checkbox" class="form-label form-check-label">Info public</label>
                            <input type="checkbox" class="form-check-input" id="info-public-checkbox" name="info_public" {% if cape.info_public %}checked{% endif %}>
                        </div>
                        <!--
                        TODO: add ability to edit image
                        <div class="mb-3">
                            <label for="cape-file" class="form-label fw-bold">Cape file</label>
                            <input type="file" class="form-control" id="cape-file" name="file" required accept=".png">
                        </div>
                        -->
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary" form="edit-cape-form">Edit</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="add-user-modal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h1 class="modal-title fs-5">Add user</h1>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form action="{{ url_for("admin_cape_add_user", cape_id=cape.id) }}" method="POST" id="add-user-form">
                        <div class="mb-3">
                            <label for="name-input" class="form-label fw-bold">Username</label>
                            <input type="text" class="form-control" id="name-input" name="username" required>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary" form="add-user-form">Add</button>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
